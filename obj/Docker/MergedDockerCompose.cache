name: dockercompose13580180153500419072
services:
  exam:
    build:
      context: D:\code\унік\Курс-2\Патерни\Lab_6\Exam
      dockerfile: Exam/Dockerfile
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "8080"
      ASPNETCORE_HTTPS_PORTS: "8081"
    image: exam
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        protocol: tcp
      - mode: ingress
        target: 8081
        protocol: tcp
    volumes:
      - type: bind
        source: C:\Users\smart\AppData\Roaming/Microsoft/UserSecrets
        target: /home/app/.microsoft/usersecrets
        read_only: true
        bind: {}
      - type: bind
        source: C:\Users\smart\AppData\Roaming/Microsoft/UserSecrets
        target: /root/.microsoft/usersecrets
        read_only: true
        bind: {}
      - type: bind
        source: C:\Users\smart\AppData\Roaming/ASP.NET/Https
        target: /home/app/.aspnet/https
        read_only: true
        bind: {}
      - type: bind
        source: C:\Users\smart\AppData\Roaming/ASP.NET/Https
        target: /root/.aspnet/https
        read_only: true
        bind: {}
networks:
  default:
    name: dockercompose13580180153500419072_default